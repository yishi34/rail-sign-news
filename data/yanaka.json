  "trains": {
    "title": "車両紹介",
    "en": "ROLLING STOCK",
    "items": [
      {
        "name": "303系",
        "description": "303系は、谷中日本鉄道が初めて自社で作った車両です。1965年に作られたのが前期車、1966年に作られたのが後期車で、今も現役で活躍中です。",
        "photos": [
          { "image": "/yanaka/trains/303-early.jpg", "imageAlt": "谷鉄303系 前期車", "caption": "前期車", "built": "1965年製造" },
          { "image": "/yanaka/trains/303-late.jpg", "imageAlt": "谷鉄303系 後期車", "caption": "後期車", "built": "1966年製造" }
        ]
      },
      {
        "name": "YT5000系",
        "description": "YT5000系は、谷中日本鉄道の特急用車両です。1990年に登場し、JR九州の783系をベースに開発されました。クリーム色の車体に緑と黄のラインをまとい、谷中日本鉄道のさまざまな特急列車で活躍しています。",
        "photos": [
          { "image": "/yanaka/trains/yt5000.jpg", "imageAlt": "谷鉄YT5000系 特急車両", "built": "1990年製造", "focus": "right" }
        ]
      },
      {
        "name": "Y325系",
        "description": "Y325系は、2000年に登場した谷中日本鉄道初のステンレス車両です。ローカル線の普通電車から本線の優等種別まで幅広く運用され、通勤・近郊輸送を支えています。",
        "photos": [
          { "image": "/yanaka/trains/y325.jpg", "imageAlt": "谷鉄Y325系 近郊型車両", "built": "2000年製造", "focus": "right" }
        ]
      },
      {
        "name": "YT360系（特急いずみ）",
        "description": "YT360系は、東京と大阪を結ぶ看板特急「いずみ」用の車両です。2015年に登場し、JR西日本の681系をベースに開発された鋼鉄車で、特急いずみの専属車両として運用されています。白い車体に青のラインをまとい、雪深い山あいから大都市まで、東阪を駆け抜けます。",
        "photos": [
          { "image": "/yanaka/trains/yt360-izumi.jpg", "imageAlt": "谷鉄YT360系 特急いずみ", "built": "2015年製造", "ratio": "512/279" }
        ]
      },
      {
        "name": "YK8500系",
        "description": "YK8500系は、2012年に登場したステンレス車両です。京王線への直通運転に対応するほか、本線では快速・急行などの優等運用にも幅広く活躍しています。4両・6両・8両編成があり、路線や時間帯に応じて柔軟に運用されています。",
        "photos": [
          { "image": "/yanaka/trains/yk8500.jpg", "imageAlt": "谷鉄YK8500系", "built": "2012年製造", "focus": "right" }
        ]
      }
    ]
